{
  "name": "vanta-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/cli.js",
  "files": ["dist", "README.md", "ARCHITECTURE.md", "AGENTS.md", "docs"],
  "bin": {
    "vanta-cli": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@types/node": "^18.19.68",
    "commander": "^12.1.0",
    "typescript": "^5.7.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.30.3"
}
